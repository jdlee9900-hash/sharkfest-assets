# ─────────────────────────────────────────────────────────────────────────────
# SharkFest environment variables
# Copy to `.env.local` for local dev and fill in real values. In production set
# these in your host (e.g. Vercel → Project → Settings → Environment Variables).
# Never commit real secrets — only this example file is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
# Public base URL. Used for Stripe success/cancel/return URLs and email links.
NEXT_PUBLIC_SITE_URL=https://sharkfest.vercel.app

# Comma-separated admin emails. These accounts can reach /admin and /admin/members.
ADMIN_EMAILS=you@example.com,committee@example.com

# Festival registration is CLOSED by default ("signups coming soon"). When you're
# ready to take bookings for an event, set REGISTRATION_OPEN_<year>=true
# (e.g. REGISTRATION_OPEN_2027=true). Setting =false also explicitly closes it.
# REGISTRATION_OPEN_2027=true

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key — server-side only, full DB access. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use TEST keys/prices in dev and LIVE keys/prices in production — never mix them.
STRIPE_SECRET_KEY=sk_test_xxx
# Per-endpoint signing secret from Stripe → Developers → Webhooks.
# Differs between test and live mode.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring price IDs for membership (Stripe → Product catalog), one per tier:
#   Playing Sharks Member (incl. family/partner)  — STRIPE_PRICE_PLAYING       (£2.50/mo)
#   Non-Playing Social Family                      — STRIPE_PRICE_SOCIAL_FAMILY (£1.50/mo)
#   Non-Playing Single Social                      — STRIPE_PRICE_SOCIAL_SINGLE (£1.00/mo)
# The prices SHOWN on the site come from the admin Pricing page; the amount actually
# charged is whatever these Stripe prices are set to — keep the two in sync.
# The older INDIVIDUAL/FAMILY/MONTHLY/ANNUAL names are still read as fallbacks.
STRIPE_PRICE_PLAYING=price_playing_xxx
STRIPE_PRICE_SOCIAL_FAMILY=price_social_family_xxx
STRIPE_PRICE_SOCIAL_SINGLE=price_social_single_xxx
STRIPE_PRICE_INDIVIDUAL=price_individual_xxx
STRIPE_PRICE_FAMILY=price_family_xxx

# ── Membership ────────────────────────────────────────────────────────────────
# Percentage discount active members get on SharkFest 2027 registration/tickets,
# applied automatically when an admin allocates their payment plan. Defaults to 10.
MEMBER_DISCOUNT_PERCENT=10

# ── Email (SMTP, e.g. Brevo) ──────────────────────────────────────────────────
# If SMTP_USER / SMTP_PASS are unset, emails are skipped (logged, not sent).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
# Friendly From header. Falls back to "SharkFest <SMTP_USER>" if unset.
EMAIL_FROM=SharkFest <noreply@example.com>

# ── Cloudinary (image hosting) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
