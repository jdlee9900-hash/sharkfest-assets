# ─────────────────────────────────────────────────────────────────────────────
# SharkFest environment variables
# Copy to `.env.local` for local dev and fill in real values. In production set
# these in your host (e.g. Vercel → Project → Settings → Environment Variables).
# Never commit real secrets — only this example file is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
# Public base URL. Used for Stripe success/cancel/return URLs and email links.
NEXT_PUBLIC_SITE_URL=https://sharkfest.vercel.app

# Comma-separated admin emails. These accounts can reach /admin and /admin/members.
ADMIN_EMAILS=you@example.com,committee@example.com

# Set to "true" to open festival registration; anything else keeps it closed.
REGISTRATION_OPEN=false

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key — server-side only, full DB access. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use TEST keys/prices in dev and LIVE keys/prices in production — never mix them.
STRIPE_SECRET_KEY=sk_test_xxx
# Per-endpoint signing secret from Stripe → Developers → Webhooks.
# Differs between test and live mode.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring price IDs for membership (Stripe → Product catalog).
STRIPE_PRICE_MONTHLY=price_monthly_xxx
STRIPE_PRICE_ANNUAL=price_annual_xxx

# ── Membership ────────────────────────────────────────────────────────────────
# Percentage discount active members get on SharkFest 2028 registration/tickets,
# applied automatically when an admin allocates their payment plan. Defaults to 10.
MEMBER_DISCOUNT_PERCENT=10

# ── Email (SMTP, e.g. Brevo) ──────────────────────────────────────────────────
# If SMTP_USER / SMTP_PASS are unset, emails are skipped (logged, not sent).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
# Friendly From header. Falls back to "SharkFest <SMTP_USER>" if unset.
EMAIL_FROM=SharkFest <noreply@example.com>

# ── Cloudinary (image hosting) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
